# Public application URL
BETTER_AUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Neon Postgres
DATABASE_URL=

# Google OAuth web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Cloud KMS symmetric key resource name
# projects/PROJECT/locations/LOCATION/keyRings/RING/cryptoKeys/KEY
GOOGLE_CLOUD_KMS_KEY_NAME=

# Minified service-account JSON with only KMS encrypt/decrypt permission
GOOGLE_CLOUD_CREDENTIALS_JSON=

# Generate with: openssl rand -base64 32
SHORTCUT_TOKEN_PEPPER=

# Match the configured Neon point-in-time recovery window exactly.
DATA_BACKUP_RETENTION_DAYS=7
